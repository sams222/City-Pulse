{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export -p web",
    "deploy:web": "npm --prefix .. run deploy:web",
    "build:preview:android": "eas build -p android --profile preview",
    "build:preview:ios": "eas build -p ios --profile preview",
    "build:prod:android": "eas build -p android --profile production",
    "build:prod:ios": "eas build -p ios --profile production",
    "submit:android": "eas submit -p android --profile production",
    "submit:ios": "eas submit -p ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "54.0.6",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.11.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
