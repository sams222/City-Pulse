# Copy to ".env" in this folder. Restart "npx expo start" after changes.

# Firebase (needs EXPO_PUBLIC_* so the JS bundle can talk to Firebase)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Maps — no EXPO_PUBLIC_ prefix; app.config.js injects this into the app securely via expo.extra.
# Enable "Maps SDK for Android" (and iOS if you use Google Maps on iPhone).
GOOGLE_MAPS_API_KEY=

# Optional: NYC Open Data app token (raises Socrata rate limits). Same value can use EXPO_PUBLIC_ prefix.
# NYC_OPEN_DATA_APP_TOKEN=

# Optional: path to Firebase service account JSON (for `npm run seed:firestore` from repo root). Do not commit the file.
# FIREBASE_SERVICE_ACCOUNT=C:\path\to\serviceAccount.json
