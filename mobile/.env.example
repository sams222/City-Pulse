# Prefer a single `City-Pulse/.env` at the repo root (merged with optional `mobile/.env`; root wins on duplicates).
# Restart Expo after changes.

# Firebase (needs EXPO_PUBLIC_* so the JS bundle can talk to Firebase)
# In Firebase Console → Authentication → Sign-in method, enable Email/Password and Google.
# Usernames use synthetic @citypulse.app emails for email/password sign-up.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Maps — no EXPO_PUBLIC_ prefix; app.config.js injects this into the app securely via expo.extra.
# Enable "Maps SDK for Android" (and iOS if you use Google Maps on iPhone).
GOOGLE_MAPS_API_KEY=

# Google Sign-In: values are read in app.config.js and passed via expo.extra (works without EXPO_PUBLIC_ prefix).
# Web client ID = Firebase Console → Project settings → Your apps (Web). Native sign-in needs this on device.
#
# If Google says the app "doesn't comply with OAuth 2.0 policy": open Google Cloud (same project as Firebase) →
# APIs & Services → OAuth consent screen — complete all required fields, add Test users (every Gmail that will
# sign in) while Publishing status is "Testing", or publish the app for production. See:
# https://support.google.com/cloud/answer/10311615
#
# In Google Cloud Console → Credentials → OAuth 2.0 Web client → Authorized redirect URIs, add:
#   https://auth.expo.io/@YOUR_EXPO_USERNAME/city-pulse
# (run `expo whoami`, use slug "city-pulse" from app.config.js). Required for Expo Go or you may get HTTP 400.
# GOOGLE_WEB_CLIENT_ID=   (or EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID)
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=   (or GOOGLE_IOS_CLIENT_ID for release builds)
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=   (or GOOGLE_ANDROID_CLIENT_ID)

# Gemini: use GEMINI_API_KEY in this file (loaded by app.config.js → expo.extra). Restart Expo after changes.
# GEMINI_API_KEY=
# Optional: GEMINI_MODEL=gemini-2.5-flash

# Optional: NYC Open Data app token (raises Socrata rate limits). Same value can use EXPO_PUBLIC_ prefix.
# NYC_OPEN_DATA_APP_TOKEN=

# Optional: path to Firebase service account JSON (for `npm run seed:firestore` from repo root). Do not commit the file.
# FIREBASE_SERVICE_ACCOUNT=C:\path\to\serviceAccount.json
